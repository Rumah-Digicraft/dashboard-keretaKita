rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rute_commuter_maps_metadata/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
