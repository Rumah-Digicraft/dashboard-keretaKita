rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // For infoStasiun
    match /infoStasiun/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null;
    }
    
    // For kaCommuter (Commuter Maps)
    match /kaCommuter/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null;
    }
    
    // Default rule: reject all others
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
